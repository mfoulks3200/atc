{
  "name": "atc",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n daemon,web -c blue,green \"pnpm --filter @atc/daemon start\" \"pnpm --filter @atc/web dev\"",
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "format": "prettier --write 'packages/*/src/**/*.ts'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts'",
    "docs:dev": "pnpm --filter @atc/docs dev",
    "docs:build": "pnpm --filter @atc/docs build"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vitest": "^3.1.1"
  }
}
